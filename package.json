{
  "name": "@caoruhua/open-claude-remote",
  "version": "0.1.6",
  "description": "Remote control proxy for Claude Code CLI - control your PC terminal from mobile browser",
  "keywords": [
    "claude",
    "claude-code",
    "remote",
    "terminal",
    "proxy",
    "mobile"
  ],
  "author": "caoruhua",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/StephenTowne/open-claude-remote.git"
  },
  "type": "module",
  "main": "./dist/backend/src/index.js",
  "types": "./dist/backend/src/index.d.ts",
  "bin": {
    "claude-remote": "./dist/backend/src/cli.js"
  },
  "imports": {
    "#shared": "./shared/index.ts"
  },
  "files": [
    "dist/",
    "frontend-dist/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently --kill-others --handle-input -n backend,frontend -c blue,green \"tsx backend/src/index.ts\" \"cd frontend && vite\"",
    "dev:cli": "tsx backend/src/cli.ts",
    "build": "tsc && tsc-alias && cd frontend && vite build",
    "start": "node dist/backend/src/index.js",
    "test": "vitest run",
    "test:unit": "vitest run --project backend backend/tests/unit --project frontend",
    "test:integration": "vitest run --project backend backend/tests/integration",
    "test:backend": "vitest run --project backend",
    "test:frontend": "vitest run --project frontend",
    "test:watch": "vitest",
    "stop": "tsx backend/src/registry/stop-instances.ts",
    "clean": "rm -rf dist frontend-dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "cookie": "^1.1.1",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "node-pty": "^1.1.0",
    "pino": "^9.14.0",
    "qrcode-terminal": "^0.12.0",
    "web-push": "^3.6.7",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/cookie": "^0.6.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.13",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "concurrently": "^9.2.1",
    "happy-dom": "^20.8.3",
    "jsdom": "^26.1.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4",
    "zustand": "^5.0.11"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty"
    ]
  }
}
