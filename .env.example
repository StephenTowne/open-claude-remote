# Server port
PORT=3000

# Bind host (auto-detected LAN IP if not set)
# HOST=192.168.1.100

# Claude Code CLI command
CLAUDE_COMMAND=claude

# Additional Claude CLI arguments (JSON array)
# CLAUDE_ARGS=["--no-telemetry"]

# Working directory for Claude Code
# CLAUDE_CWD=/path/to/project

# Fixed auth token (auto-generated if not set)
# AUTH_TOKEN=your-secret-token

# Session TTL in milliseconds (default: 24 hours)
# SESSION_TTL=86400000

# Auth rate limit (attempts per minute per IP)
# AUTH_RATE_LIMIT=5

# Output buffer max lines
# MAX_BUFFER_LINES=10000

# Log directory
# LOG_DIR=./logs
