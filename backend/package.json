{
  "name": "@caoruhua/open-claude-remote",
  "version": "0.1.1",
  "description": "Remote control proxy for Claude Code CLI - control your PC terminal from mobile browser",
  "keywords": [
    "claude",
    "claude-code",
    "remote",
    "terminal",
    "proxy",
    "mobile"
  ],
  "author": "caoruhua",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/StephenTowne/open-claude-remote.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "claude-remote": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "shared-dist/",
    "frontend-dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "prepack": "node scripts/prepack.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@claude-remote/shared": "workspace:*",
    "cookie": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "node-pty": "^1.0.0",
    "pino": "^9.6.0",
    "qrcode-terminal": "^0.12.0",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-code": ">=0.0.1"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-code": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "os": [
    "darwin",
    "linux"
  ]
}